# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL - sesuaikan dengan port backend Anda
VITE_API_BASE_URL=http://localhost:5000

# ============================================
# APP CONFIGURATION
# ============================================
VITE_APP_NAME=Dagsap JNT Internal App
VITE_APP_VERSION=1.0.0

# ============================================
# ENVIRONMENT
# ============================================
VITE_ENV=development

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

# ============================================
# DEVELOPMENT
# ============================================
# Set ke true untuk verbose logging di console
VITE_DEBUG=false
# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_NAME="Dagsap JNT Internal App Backend"
PORT=5000
NODE_ENV=development
TIMEZONE=+07:00

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dagsap_app_dev
DB_USER=root
DB_PASSWORD=your_database_password
DB_DIALECT=mysql

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# EMAIL CONFIGURATION (Optional - untuk forgot password)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@dagsap-app.com

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:5173

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=10

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_DIR=logs
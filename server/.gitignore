# ============================================
# UPLOADS - Ignore actual files but keep folder
# ============================================
# Ignore all uploaded files but keep the directory structure
public/uploads/**
# But DO NOT ignore .gitkeep files (they're needed to keep folders in git)
!public/uploads/**/.gitkeep
!public/uploads/.gitkeep